# Event date + time are interpreted in this IANA zone.
EVENT_TIMEZONE="America/Chicago"

# Admin UI at /admin/login — set a strong passcode in production.
ADMIN_PASSCODE="rekab"
# Min 16 characters; required for signing admin session cookies in production.
ADMIN_JWT_SECRET="change-me-16chars-min"

# --- Google Sheets (required for saving quotes, admin queue, inventory, pricing) ---
# Service account must be Editor on the spreadsheet. Enable Google Sheets API in GCP.
GOOGLE_SHEET_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
# One line, double-quoted, real newlines as \n (required for dotenv & Netlify):
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=""

# Tab names (missing tabs are created automatically on first use except your existing layout)
GOOGLE_SHEET_PENDING_TAB="SubmitRequests"
GOOGLE_SHEET_INVENTORY_TAB="Inventory"
GOOGLE_SHEET_PRICES_TAB="Prices"
GOOGLE_SHEET_RESERVATIONS_TAB="LetterReservations"

# Optional: identify your app to Nominatim
# NOMINATIM_USER_AGENT="LuxMarquee/1.0 (you@domain.com)"

# Optional: enables Google Places autocomplete on street address input
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# --- Resend: calendar .ics emails on "Confirm booking" (https://resend.com) ---
# 1. Sign up → API Keys → create a key (starts with re_).
# 2. Domains → add your domain → add DNS records → wait for Verified.
# 3. Use a sender on that domain, e.g. bookings@yourdomain.com (must match verified domain).
# 4. Paste values below, save, then restart `npm run dev` locally or redeploy on Netlify.
#    Until these are set, booking still works; the admin card shows "Download calendar (.ics)".
RESEND_API_KEY=""
RESEND_FROM_EMAIL="bookings@yourverifieddomain.com"
BUSINESS_OWNER_EMAIL="your-personal-inbox@gmail.com"

# Admin queue: prefilled SMS/WhatsApp welcome (placeholders: {{name}} {{eventDate}} {{time}})
NEXT_PUBLIC_ADMIN_WELCOME_SMS_TEMPLATE="Hi {{name}}! Thanks for choosing Lux Marquee Rentals. We received your request and will follow up shortly — reply here anytime."

# Optional: Facebook Page username for Messenger inbox link (https://m.me/<this>) — not client phone
NEXT_PUBLIC_BUSINESS_MESSENGER_MME=""
